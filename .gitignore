# ============================================================
# mentask — .gitignore
# Comprehensive Python project ignore rules
# ============================================================

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
.conda/
ENV/
env/
.venv/
venv/

# ------------------------------------------------------------
# Python Cache & Bytecode
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------------------------------------
# Build, Distribution & Packaging
# ------------------------------------------------------------
*.egg
*.egg-info/
*.tar.gz
*.whl
Artifacts/
build/
dist/
docs/Artifacts/
MANIFEST

# ------------------------------------------------------------
# Testing, Coverage & Linting
# ------------------------------------------------------------
.coverage
.mypy_cache/
.nox/
.pytest_cache/
.ruff_cache/
.tox/
*.cover
coverage.xml
htmlcov/

# ------------------------------------------------------------
# IDE & Editor Configuration
# ------------------------------------------------------------
.idea/
.vs/
.vscode/
*.code-workspace
*.iml
*.swo
*.swp
*~
Writerside/

# ------------------------------------------------------------
# OS-specific files
# ------------------------------------------------------------
.DS_Store
Desktop.ini
Thumbs.db
ehthumbs.db

# ------------------------------------------------------------
# Secrets, Local Configuration & Sensitive Data
# ------------------------------------------------------------
.env
.env.*
.gemini_api_key_encrypted
.gemini_api_key_unencrypted
*.ini
claude_audit.md
gha-creds-*.json
local_settings.py
mentask_knowledge.md
openssf_audit.md
qp_audit.md

# ------------------------------------------------------------
# Logs, Backups & User Data
# ------------------------------------------------------------
.askgem/
.gemini/
.gemini_chatbot_prefs.json
.mentask/
*.bak
*.bkp
*.log
chat_history_*.json

# ------------------------------------------------------------
# Tooling & Service-specific files
# ------------------------------------------------------------
.promptbooster.yml
.snapshots/
codeql-custom-queries-actions/
codeql-custom-queries-python/
prompt_drafts.md

# ------------------------------------------------------------
# Project-specific & Generated files
# ------------------------------------------------------------
.github/agents/
.github/codeql/
.scratch/
.scripts/
_reference_code/
FEATURES.md
holamundo.md
identity.md
scripts/cleanup_branches.sh

# ------------------------------------------------------------
# Docker (not currently used)
# ------------------------------------------------------------
.dockerignore
Dockerfile
README.Docker.md
compose*.yaml
docker-compose*.yml
