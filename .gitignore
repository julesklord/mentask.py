# ============================================================
# askgem — .gitignore
# Comprehensive Python project ignore rules
# ============================================================

# ---------------------- Virtual Environments ------------------
.venv/
venv/
ENV/
env/
.conda/

# ---------------------- Python Cache --------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ---------------------- Build Artifacts -----------------------
build/
dist/
*.egg-info/
*.egg
MANIFEST
*.whl
*.tar.gz
Artifacts

# ---------------------- Testing & Linting ---------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.ruff_cache/
.mypy_cache/
coverage.xml
*.cover

# ---------------------- IDE & Editor --------------------------
.idea/
.vscode/
*.code-workspace
Writerside/
*.iml
*.swp
*.swo
*~

# ---------------------- OS Files ------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---------------------- Secrets & Local Config ----------------
.env
.env.*
.gemini_api_key_encrypted
.gemini_api_key_unencrypted
local_settings.py

# ---------------------- Legacy User Data ----------------------
.gemini_chatbot_prefs.json
chat_history_*.json

# ---------------------- Logs & Backups ------------------------
*.log
*.bkp
*.bak

# ---------------------- Third-Party Tool Artifacts ------------
# External reference code (local study material, not project code)
_reference_code/

# VS Code extension scratch files
.promptbooster.yml
prompt_drafts.md

# Snapshot tools
.snapshots/

# ---------------------- Docker (not currently used) -----------
Dockerfile
docker-compose*.yml
compose*.yaml
.dockerignore
README.Docker.md
holamundo.md
identity.md
.github/agents/debug-python.agent.md
scripts/cleanup_branches.sh
